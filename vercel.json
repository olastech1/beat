{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/",         "destination": "/index.html" },
    { "source": "/for-you",  "destination": "/discover.html" },
    { "source": "/discover", "destination": "/discover.html" },
    { "source": "/store",    "destination": "/index.html" },
    { "source": "/login",    "destination": "/login.html" },
    { "source": "/seller",   "destination": "/seller.html" },
    { "source": "/buyer",    "destination": "/buyer.html" },
    { "source": "/admin",    "destination": "/admin.html" }
  ],
  "ignoreCommand": "echo done"
}
